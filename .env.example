# Configuração de ambiente — Harness IA RH (Fase 0)
# Copie para .env e ajuste. NUNCA versione segredos reais.

# Identificação e ambiente
APP_NAME=rh-geral-harness
ENVIRONMENT=dev            # dev | staging | prod
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# Banco de metadados (SQLite em dev)
DATABASE_URL=sqlite:///./rh_harness.db

# Logging
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=true

# Segurança — DEVE ser sobrescrito em produção por uma chave forte
SECRET_KEY=change-me-in-production

# ── Harness completo (Fase 3) ───────────────────────────────────────────────
# Seleção de modelo: auto | economico | intermediario | robusto
MODEL_SELECTION_STRATEGY=auto
# Orçamento máximo de custo estimado (USD) por resposta
COST_BUDGET_PER_ANSWER=0.05
# Cache semântico
CACHE_ENABLED=true
CACHE_SIMILARITY_THRESHOLD=0.92
# Prompt registry versionado
PROMPT_REGISTRY_DIR=prompts
# Confiança mínima de roteamento antes de escalar para revisão humana
HUMAN_REVIEW_MIN_CONFIDENCE=0.34

# ── API Keys de LLMs ─────────────────────────────────────────────────────────
# OPENAI_API_KEY é obrigatória para usar GPT-4o/GPT-4o-mini
OPENAI_API_KEY=sk-your-openai-key-here

# MINIMAX_API_KEY é opcional - habilita modelo gratuito para tarefas simples
# Obtain at: https://platform.minimax.io/
MINIMAX_API_KEY=your-minimax-key-here

# ── Modelos por Nível de Dificuldade ─────────────────────────────────────────
# Configure qual modelo usar para cada nível de dificuldade:
# - economico: tarefas simples (buscas, extração, greetings)
# - intermediario: tarefas médias (explicações, comparações)
# - robusto: tarefas complexas (análise, síntese, casos específicos)
#
# Modelos disponíveis: gpt-4o, gpt-4o-mini, minimax-m2.5
MODEL_ECONOMICO=minimax-m2.5
MODEL_INTERMEDIARIO=gpt-4o-mini
MODEL_ROBUSTO=gpt-4o

# Temperatura da geração (0.0 = mais factual, 1.0 = mais criativo)
MODEL_TEMPERATURE=0.3
